---
import Base from './Base.astro';
import type { Lang } from '../i18n/index';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    lang?: string;
  };
}

const { frontmatter } = Astro.props;
const lang = (frontmatter.lang ?? 'en') as Lang;
---

<Base lang={lang} title={`${frontmatter.title} — KRouter`} description={frontmatter.description}>
  <div class="docs-page section" style="padding-top: calc(var(--space-20) + 3.5rem);">
    <div class="container docs-container">
      <article class="prose docs-prose">
        <slot />
      </article>
    </div>
  </div>
</Base>

<style>
  .docs-container {
    max-width: 52rem;
  }

  .docs-prose :global(h1) {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--color-ink);
    margin-bottom: var(--space-6);
    overflow-wrap: anywhere;
    min-width: 0;
  }

  .docs-prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-rule-2);
    overflow-wrap: anywhere;
    min-width: 0;
  }

  .docs-prose :global(h2:first-of-type) { border-top: none; padding-top: 0; }

  .docs-prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    overflow-wrap: anywhere;
    min-width: 0;
  }

  .docs-prose :global(p) {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-ink-2);
    margin-bottom: var(--space-4);
    max-width: 72ch;
  }

  .docs-prose :global(ul), .docs-prose :global(ol) {
    padding-left: 1.25rem;
    margin-block: var(--space-4);
  }

  .docs-prose :global(li) {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-ink-2);
    margin-bottom: var(--space-2);
  }

  .docs-prose :global(a) {
    color: var(--color-accent-text);
    text-underline-offset: 2px;
  }

  .docs-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-paper-2);
    border: 1px solid var(--color-rule-2);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    color: var(--color-ink);
  }

  .docs-prose :global(pre) {
    background: var(--color-ink);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    overflow-x: auto;
    margin-block: var(--space-6);
  }

  .docs-prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: oklch(90% 0.010 148);
    font-size: 0.8125rem;
    line-height: 1.7;
  }

  .docs-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-block: var(--space-6);
    font-size: 0.875rem;
    overflow-x: auto;
    display: block;
  }

  .docs-prose :global(th) {
    text-align: left;
    font-weight: 600;
    color: var(--color-ink);
    padding: var(--space-3) var(--space-4);
    border-bottom: 2px solid var(--color-rule);
    white-space: nowrap;
  }

  .docs-prose :global(td) {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-rule-2);
    color: var(--color-ink-2);
    vertical-align: top;
  }

  .docs-prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    margin-left: 0;
    padding-left: var(--space-6);
    color: var(--color-ink-2);
  }

  .docs-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-rule-2);
    margin-block: var(--space-12);
  }
</style>
