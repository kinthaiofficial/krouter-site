---
import Base from '../layouts/Base.astro';
import { t } from '../i18n/index';

const lang = 'en';
const i = t(lang);

let changelogContent = '';
try {
  // Fetched during CI build; at dev time falls back to empty
  const res = await fetch(
    'https://raw.githubusercontent.com/kinthaiofficial/krouter/main/CHANGELOG.md'
  );
  if (res.ok) changelogContent = await res.text();
} catch {
  changelogContent = '## Changelog\n\nSee [GitHub releases](https://github.com/kinthaiofficial/krouter/releases) for the full changelog.';
}

import { marked } from 'marked';
const html = await marked.parse(changelogContent);
---

<Base
  lang={lang}
  title="KRouter Changelog — Release Notes and Version History"
  description="Release notes and version history for KRouter, the intelligent LLM router for AI agents."
>
  <section class="section" style="padding-top: calc(var(--space-20) + 3.5rem);">
    <div class="container changelog-container">
      <h1 class="display-md" style="margin-bottom: var(--space-4);">{i.changelog.heading}</h1>
      <p class="body-lg" style="margin-bottom: var(--space-12);">{i.changelog.sub}</p>
      <div class="changelog-body prose" set:html={html} />
    </div>
  </section>
</Base>

<style>
  .changelog-container {
    max-width: 52rem;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-rule-2);
  }

  .prose :global(h2:first-child) { border-top: none; padding-top: 0; }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink-2);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .prose :global(ul) {
    padding-left: 1.25rem;
    margin-block: var(--space-3);
  }

  .prose :global(li) {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-ink-2);
    margin-bottom: var(--space-2);
  }

  .prose :global(a) {
    color: var(--color-accent-text);
    text-underline-offset: 2px;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-paper-2);
    border: 1px solid var(--color-rule-2);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    color: var(--color-ink);
  }

  .prose :global(pre) {
    background: var(--color-ink);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    overflow-x: auto;
    margin-block: var(--space-6);
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: oklch(90% 0.010 148);
    font-size: 0.8125rem;
  }
</style>
