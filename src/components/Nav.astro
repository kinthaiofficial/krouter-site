---
import type { Lang } from '../i18n/index';
import type { en } from '../i18n/en';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  lang: Lang;
  i: typeof en;
}

const { lang, i } = Astro.props;
const base = lang === 'zh' ? '/zh' : '';
---

<header class="nav-wrap" role="banner">
  <nav class="nav-pill" aria-label="Main navigation">
    <a href={`${base}/`} class="nav-logo" aria-label="krouter home">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <!-- K letter mark in brand green -->
        <rect width="28" height="28" rx="7" fill="oklch(15% 0.010 148)"/>
        <path d="M8 7h3v5.5L16.5 7H20l-6.2 6.2L20.5 21H17l-5-5.8-1 .9V21H8V7z" fill="oklch(77% 0.188 148)"/>
      </svg>
      <span class="nav-logo__name">krouter</span>
    </a>

    <div class="nav-links" role="list">
      <a href={`${base}/#agents`} class="nav-link" role="listitem">{i.nav.agents}</a>
      <a href={`${base}/#providers`} class="nav-link" role="listitem">{i.nav.providers}</a>
      <a href={`${base}/download`} class="nav-link" role="listitem">{i.nav.download}</a>
      <a href={`${base}/docs/getting-started`} class="nav-link" role="listitem">{i.nav.docs}</a>
    </div>

    <div class="nav-actions">
      <LangSwitcher lang={lang} />
      <a
        href="https://github.com/kinthaiofficial/krouter"
        class="nav-github"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View krouter on GitHub"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        {i.nav.github}
      </a>
    </div>
  </nav>
</header>

<style>
  .nav-wrap {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    padding: 1rem 1.5rem;
    pointer-events: none;
  }

  .nav-pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: oklch(99% 0.005 148 / 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid oklch(84% 0.008 148);
    border-radius: 9999px;
    padding: 0.4375rem 0.5rem 0.4375rem 0.625rem;
    box-shadow: var(--shadow-nav);
    max-width: 56rem;
    width: 100%;
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 9999px;
    flex-shrink: 0;
  }

  .nav-logo__name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0;
    margin-left: 0.25rem;
    flex: 1;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-2);
    text-decoration: none;
    padding: 0.3125rem 0.75rem;
    border-radius: 9999px;
    transition: color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-ink);
    background: var(--color-paper-2);
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .nav-github {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-paper);
    background: var(--color-ink);
    text-decoration: none;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    border: 1.5px solid var(--color-ink);
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }

  .nav-github:hover { opacity: 0.82; }

  .nav-github:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .nav-wrap { padding: 0.75rem 1rem; }
    .nav-links { display: none; }
    .nav-pill { padding: 0.375rem 0.5rem; }
  }

  @media (max-width: 480px) {
    .nav-github span { display: none; }
  }
</style>
